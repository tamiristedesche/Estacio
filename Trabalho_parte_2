    # -----------------------------------------------------------------
    # Criar tabela de exibição dos alunos
    # -----------------------------------------------------------------
    def criar_tabela(self):
        """
        FUNÇÃO: criar_tabela()
        OBJETIVO: Criar a tabela (Treeview) para exibir os alunos com cores
        COLUNAS: Seleção, ID, Nome, Matrícula, Curso, Nota 1, Nota 2, Média, Situação
        """
        # Frame com borda e título
        frame_tabela = tk.LabelFrame(
            self.root, text="📋 Lista de Alunos Cadastrados", 
            font=('Arial', 10, 'bold'), bg='#f0f0f0', fg='#2c3e50',
            padx=10, pady=10
        )
        frame_tabela.pack(fill=tk.BOTH, expand=True, padx=10, pady=5)
        
        # Scrollbars para rolar a tabela
        scroll_y = ttk.Scrollbar(frame_tabela)
        scroll_y.pack(side=tk.RIGHT, fill=tk.Y)
        
        scroll_x = ttk.Scrollbar(frame_tabela, orient=tk.HORIZONTAL)
        scroll_x.pack(side=tk.BOTTOM, fill=tk.X)
        
        # Treeview (tabela) com 9 colunas
        self.tree = ttk.Treeview(
            frame_tabela,
            columns=('Seleção', 'ID', 'Nome', 'Matrícula', 'Curso', 'Nota 1', 'Nota 2', 'Média', 'Situação'),
            show='headings',
            yscrollcommand=scroll_y.set,
            xscrollcommand=scroll_x.set,
            height=18
        )
        
        # Conectar as scrollbars à tabela
        scroll_y.config(command=self.tree.yview)
        scroll_x.config(command=self.tree.xview)
        
        # Configurar cada coluna (largura e alinhamento)
        colunas = {
            'Seleção': {'width': 60, 'anchor': 'center'},
            'ID': {'width': 50, 'anchor': 'center'},
            'Nome': {'width': 220, 'anchor': 'w'},
            'Matrícula': {'width': 100, 'anchor': 'center'},
            'Curso': {'width': 150, 'anchor': 'w'},
            'Nota 1': {'width': 80, 'anchor': 'center'},
            'Nota 2': {'width': 80, 'anchor': 'center'},
            'Média': {'width': 80, 'anchor': 'center'},
            'Situação': {'width': 110, 'anchor': 'center'}
        }
        
        # Aplicar as configurações das colunas
        for col, config in colunas.items():
            self.tree.heading(col, text=col)
            self.tree.column(col, **config)
        
        self.tree.pack(fill=tk.BOTH, expand=True)
        
        # Evento: duplo clique na tabela abre a janela de atualização
        self.tree.bind('<Double-Button-1>', lambda e: self.abrir_atualizacao())
        
        # Evento: clique na coluna de seleção
        self.tree.bind('<Button-1>', self.on_tree_click)
    
    # -----------------------------------------------------------------
    # Evento de clique na tabela
    # -----------------------------------------------------------------
    def on_tree_click(self, event):
        """Gerencia o clique na coluna de seleção da tabela"""
        region = self.tree.identify_region(event.x, event.y)
        if region == "cell":
            column = self.tree.identify_column(event.x)
            if column == '#1':  # Coluna de Seleção
                item = self.tree.identify_row(event.y)
                if item:
                    if item in self.checkboxes and self.checkboxes[item].get():
                        # Desmarcar
                        self.checkboxes[item].set(False)
                        self.tree.set(item, 'Seleção', '□')
                        self.tree.item(item, tags=('',))
                    else:
                        # Marcar
                        if item not in self.checkboxes:
                            self.checkboxes[item] = tk.BooleanVar(value=True)
                        else:
                            self.checkboxes[item].set(True)
                        self.tree.set(item, 'Seleção', '■')
                        self.tree.item(item, tags=('selected',))
                    
                    self.atualizar_label_selecionados()
    
    # -----------------------------------------------------------------
    # Criar barra de status
    # -----------------------------------------------------------------
    def criar_status_bar(self):
        """Cria a barra de status na parte inferior"""
        frame_status = tk.Frame(self.root, bg='#e8e8e8', height=35)
        frame_status.pack(fill=tk.X, side=tk.BOTTOM)
        frame_status.pack_propagate(False)
        
        self.label_selecionados = tk.Label(
            frame_status,
            text="📌 Nenhum aluno selecionado",
            font=('Arial', 9),
            bg='#e8e8e8',
            fg='#2c3e50',
            anchor='w',
            padx=10
        )
        self.label_selecionados.pack(side=tk.LEFT, fill=tk.X, expand=True)
        
        self.label_total_status = tk.Label(
            frame_status,
            text="",
            font=('Arial', 9),
            bg='#e8e8e8',
            fg='#7f8c8d',
            anchor='e',
            padx=10
        )
        self.label_total_status.pack(side=tk.RIGHT)
    
    # -----------------------------------------------------------------
    # Atualizar label de selecionados
    # -----------------------------------------------------------------
    def atualizar_label_selecionados(self):
        """Atualiza o label com a quantidade de alunos selecionados"""
        selecionados = [item for item, var in self.checkboxes.items() if var.get()]
        qtd = len(selecionados)
        
        if qtd == 0:
            self.label_selecionados.config(text="📌 Nenhum aluno selecionado")
        elif qtd == 1:
            self.label_selecionados.config(text=f"📌 1 aluno selecionado")
        else:
            self.label_selecionados.config(text=f"📌 {qtd} alunos selecionados")
        
        self.label_total_status.config(text=f"Total na tabela: {len(self.tree.get_children())}")
    
    # -----------------------------------------------------------------
    # Limpar seleções
    # -----------------------------------------------------------------
    def limpar_selecoes(self):
        """Limpa todas as seleções de checkbox"""
        for item, var in self.checkboxes.items():
            var.set(False)
            self.tree.set(item, 'Seleção', '□')
            self.tree.item(item, tags=('',))
        self.atualizar_label_selecionados()
    
    # -----------------------------------------------------------------
    # Excluir apenas os alunos selecionados
    # -----------------------------------------------------------------
    def excluir_selecionados(self):
        """
        FUNÇÃO: excluir_selecionados()
        OBJETIVO: Excluir APENAS os alunos que estão com checkbox marcado
        """
        # Pegar apenas os alunos selecionados
        selecionados = []
        for item, var in self.checkboxes.items():
            if var.get():
                valores = self.tree.item(item, 'values')
                id_aluno = valores[1]
                nome_aluno = valores[2]
                selecionados.append((id_aluno, nome_aluno))
        
        # Verificar se há alunos selecionados
        if not selecionados:
            messagebox.showwarning(
                "⚠️ Nenhum aluno selecionado",
                "Para excluir:\n\n"
                "1. Clique na coluna 'Seleção' (primeira coluna) para marcar os alunos (■)\n"
                "2. Depois clique em 'EXCLUIR'"
            )
            return
        
        # Mostrar quantos serão excluídos e pedir confirmação
        qtd = len(selecionados)
        lista_nomes = "\n".join([f"• {nome}" for id, nome in selecionados[:5]])
        if qtd > 5:
            lista_nomes += f"\n... e mais {qtd - 5} outro(s)"
        
        resposta = messagebox.askyesno(
            "🗑️ Confirmar Exclusão",
            f"⚠️ ATENÇÃO!\n\n"
            f"Você selecionou {qtd} aluno(s) para excluir:\n\n{lista_nomes}\n\n"
            f"Esta ação é IRREVERSÍVEL!\n\nDeseja continuar?",
            icon='warning'
        )
        
        if not resposta:
            return
        
        # Executar a exclusão
        excluidos = 0
        for id_aluno, nome_aluno in selecionados:
            try:
                excluir_aluno(int(id_aluno))
                excluidos += 1
            except:
                pass
        
        # Limpar seleções e atualizar
        self.limpar_selecoes()
        self.atualizar_tabela()
        
        # Mensagem de resultado
        messagebox.showinfo(
            "✅ Exclusão Concluída",
            f"{excluidos} aluno(s) foram excluído(s) com sucesso!"
        )
    
    # -----------------------------------------------------------------
    # Atualizar tabela com dados do banco
    # -----------------------------------------------------------------
    def atualizar_tabela(self):
        """
        FUNÇÃO: atualizar_tabela()
        OBJETIVO: Buscar os alunos no banco e exibir na tabela com cores
        CORES: Verde para aprovados (média >= 6), Vermelho para reprovados
        OBSERVAÇÃO: Se apenas uma nota existir, a média é calculada como nota/2
        """
        # Limpar a tabela atual
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        self.checkboxes.clear()
        
        alunos = listar_alunos()
        aprovados = 0
        
        for aluno in alunos:
            id_aluno, nome, matricula, curso, nota1, nota2 = aluno
            
            # LÓGICA PARA CÁLCULO DA MÉDIA
            # Caso 1: Duas notas disponíveis
            if nota1 is not None and nota2 is not None:
                media = (nota1 + nota2) / 2
                situacao = "APROVADO ✅" if media >= 6 else "REPROVADO ❌"
                if media >= 6:
                    aprovados += 1
            
            # Caso 2: Apenas nota 1 disponível (divide por 2)
            elif nota1 is not None and nota2 is None:
                media = nota1 / 2
                situacao = "APROVADO ✅" if media >= 6 else "REPROVADO ❌"
                if media >= 6:
                    aprovados += 1
            
            # Caso 3: Apenas nota 2 disponível (divide por 2)
            elif nota1 is None and nota2 is not None:
                media = nota2 / 2
                situacao = "APROVADO ✅" if media >= 6 else "REPROVADO ❌"
                if media >= 6:
                    aprovados += 1
            
            # Caso 4: Nenhuma nota disponível
            else:
                media = 0
                situacao = "SEM NOTAS ⚠️"
            
            # Definir a cor da linha baseada na média
            tag = 'aprovado' if media >= 6 else 'reprovado'
            
            var_check = tk.BooleanVar(value=False)
            
            item = self.tree.insert('', tk.END,
                           values=("□", id_aluno, nome, matricula, curso,
                                  f"{nota1:.1f}" if nota1 else "-",
                                  f"{nota2:.1f}" if nota2 else "-",
                                  f"{media:.1f}", situacao),
                           tags=(tag,))
            
            self.checkboxes[item] = var_check
            
            def atualizar_simbolo(i, v):
                if v.get():
                    self.tree.set(i, 'Seleção', '■')
                else:
                    self.tree.set(i, 'Seleção', '□')
            
            var_check.trace_add('write', lambda *args, i=item, v=var_check: atualizar_simbolo(i, v))
        
        # Configurar as cores das linhas
        self.tree.tag_configure('aprovado', background='#d4edda', foreground='#155724')
        self.tree.tag_configure('reprovado', background='#f8d7da', foreground='#721c24')
        self.tree.tag_configure('selected', background='#bdc3c7', foreground='#2c3e50')
        
        total = len(alunos)
        reprovados = 0
        for aluno in alunos:
            nota1, nota2 = aluno[4], aluno[5]
            if nota1 is not None and nota2 is not None:
                media = (nota1 + nota2) / 2
                if media < 6:
                    reprovados += 1
            elif nota1 is not None and nota2 is None:
                media = nota1 / 2
                if media < 6:
                    reprovados += 1
            elif nota1 is None and nota2 is not None:
                media = nota2 / 2
                if media < 6:
                    reprovados += 1
        
        self.label_total.config(text=f"📊 Total de Alunos: {total}")
        self.label_aprovados.config(text=f"✅ Aprovados: {aprovados}")
        self.label_reprovados.config(text=f"❌ Reprovados: {reprovados}")
        
        self.atualizar_label_selecionados()
    
    # -----------------------------------------------------------------
    # Mostrar estatísticas detalhadas 
    # -----------------------------------------------------------------
    def mostrar_estatisticas(self):
        """
        FUNÇÃO: mostrar_estatisticas()
        OBJETIVO: Exibir estatísticas detalhadas dos alunos por curso
        """
        # Buscar todos os alunos do banco
        alunos = listar_alunos()
        
        if not alunos:
            messagebox.showinfo("📊 Estatísticas", "Nenhum aluno cadastrado ainda!")
            return
        
        # Dicionário para armazenar estatísticas por curso
        estatisticas = {}
        
        # Processar cada aluno
        for aluno in alunos:
            id_aluno, nome, matricula, curso, nota1, nota2 = aluno
            
            # Calcular média
            if nota1 is not None and nota2 is not None:
                media = (nota1 + nota2) / 2
                situacao = "APROVADO" if media >= 6 else "REPROVADO"
            elif nota1 is not None and nota2 is None:
                media = nota1 / 2
                situacao = "APROVADO" if media >= 6 else "REPROVADO"
            elif nota1 is None and nota2 is not None:
                media = nota2 / 2
                situacao = "APROVADO" if media >= 6 else "REPROVADO"
            else:
                media = 0
                situacao = "REPROVADO"
            
            # Inicializar estatísticas do curso se não existir
            if curso not in estatisticas:
                estatisticas[curso] = {
                    'total': 0, 
                    'aprovados': 0, 
                    'reprovados': 0
                }
            
            # Atualizar estatísticas
            estatisticas[curso]['total'] += 1
            if situacao == "APROVADO":
                estatisticas[curso]['aprovados'] += 1
            else:
                estatisticas[curso]['reprovados'] += 1
        
        # Calcular totais gerais
        total_geral = 0
        aprovados_geral = 0
        reprovados_geral = 0
        
        for curso, stats in estatisticas.items():
            total_geral += stats['total']
            aprovados_geral += stats['aprovados']
            reprovados_geral += stats['reprovados']
        
        # Calcular taxas gerais
        taxa_aprovacao_geral = (aprovados_geral / total_geral * 100) if total_geral > 0 else 0
        taxa_reprovacao_geral = (reprovados_geral / total_geral * 100) if total_geral > 0 else 0
        
        # Construir o texto das estatísticas 
        texto = "=" * 80 + "\n"
        texto += "                   ESTATISTICAS DETALHADAS DA TURMA\n"
        texto += "=" * 80 + "\n\n"
        
        # Tabela por curso
        texto += "📋 POR CURSO:\n"
        texto += "-" * 80 + "\n"
        texto += f"{'Curso':<30} {'Total':>6} {'Aprovados':>10} {'Reprovados':>10} {'Aprovação':>10} {'Reprovação':>10}\n"
        texto += "-" * 80 + "\n"
        
        for curso, stats in sorted(estatisticas.items()):
            total = stats['total']
            aprovados = stats['aprovados']
            reprovados = stats['reprovados']
            taxa_aprovacao = (aprovados / total * 100) if total > 0 else 0
            taxa_reprovacao = (reprovados / total * 100) if total > 0 else 0
            
            texto += f"{curso:<30} {total:>6} {aprovados:>10} {reprovados:>10} {taxa_aprovacao:>9.1f}% {taxa_reprovacao:>9.1f}%\n"
        
        texto += "-" * 80 + "\n"
        
        # Totais gerais
        texto += f"\n 📊 TOTAIS GERAIS:\n"
        texto += "-" * 80 + "\n"
        texto += f"{'Total de Alunos':<30} {total_geral:>6}\n"
        texto += f"{'Total de Aprovados':<30} {aprovados_geral:>6}\n"
        texto += f"{'Total de Reprovados':<30} {reprovados_geral:>6}\n"
        texto += f"{'Taxa de Aprovação':<30} {taxa_aprovacao_geral:>6.1f}%\n"
        texto += f"{'Taxa de Reprovação':<30} {taxa_reprovacao_geral:>6.1f}%\n"
        texto += "-" * 80 + "\n"
        
        # Resumo visual com barras
        texto += "\n 📈 RESUMO VISUAL DA TURMA:\n"
        texto += "-" * 80 + "\n"
        
        comprimento_barra = 40
        aprovados_barra = int((aprovados_geral / total_geral) * comprimento_barra) if total_geral > 0 else 0
        reprovados_barra = comprimento_barra - aprovados_barra
        
        texto += f"Aprovados:   {'█' * aprovados_barra}{'░' * reprovados_barra} {taxa_aprovacao_geral:.1f}%\n"
        texto += f"Reprovados:  {'█' * reprovados_barra}{'░' * aprovados_barra} {taxa_reprovacao_geral:.1f}%\n"
        texto += "-" * 80 + "\n"
        
        # Informação sobre os cursos
        texto += f"\n 🏫 DISTRIBUICAO POR CURSO:\n"
        texto += "-" * 80 + "\n"
        
        for curso, stats in sorted(estatisticas.items()):
            total = stats['total']
            percentual = (total / total_geral * 100) if total_geral > 0 else 0
            barras = int((total / total_geral) * comprimento_barra) if total_geral > 0 else 0
            texto += f"{curso[:25]:<25} {total:>3} alunos ({percentual:>5.1f}%) {'█' * barras}\n"
        
        texto += "=" * 80 + "\n"
        
        # Criar janela para exibir as estatísticas
        janela = Toplevel(self.root)
        janela.title(" 📊 Estatísticas da Turma")
        janela.geometry("750x650")
        janela.configure(bg='#f0f0f0')
        
        # Centralizar a janela
        janela.update_idletasks()
        x = (janela.winfo_screenwidth() // 2) - (750 // 2)
        y = (janela.winfo_screenheight() // 2) - (650 // 2)
        janela.geometry(f'750x650+{x}+{y}')
        
        # Frame para o texto
        frame_texto = tk.Frame(janela, bg='#f0f0f0', padx=20, pady=20)
        frame_texto.pack(fill=tk.BOTH, expand=True)
        
        # Widget de texto com scroll
        text_widget = tk.Text(
            frame_texto,
            font=('Courier New', 10),
            bg='white',
            fg='#2c3e50',
            wrap=tk.NONE,
            padx=15,
            pady=15
        )
        text_widget.insert('1.0', texto)
        text_widget.config(state='disabled')
        
        # Scrollbars
        scroll_y = tk.Scrollbar(frame_texto, orient=tk.VERTICAL, command=text_widget.yview)
        scroll_x = tk.Scrollbar(frame_texto, orient=tk.HORIZONTAL, command=text_widget.xview)
        text_widget.configure(yscrollcommand=scroll_y.set, xscrollcommand=scroll_x.set)
        
        scroll_y.pack(side=tk.RIGHT, fill=tk.Y)
        scroll_x.pack(side=tk.BOTTOM, fill=tk.X)
        text_widget.pack(fill=tk.BOTH, expand=True)
        
        # Frame para os botões
        frame_botoes = tk.Frame(janela, bg='#f0f0f0', pady=15)
        frame_botoes.pack(fill=tk.X)
        
        # Botão exportar
        def exportar_estatisticas():
            nome_arquivo = f"estatisticas_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
            with open(nome_arquivo, 'w', encoding='utf-8') as f:
                f.write(texto)
            messagebox.showinfo("Exportar", f"✅ Estatísticas exportadas para:\n{nome_arquivo}")
        
        tk.Button(
            frame_botoes, text="EXPORTAR", command=exportar_estatisticas,
            bg='#27ae60', fg='white', font=('Arial', 10, 'bold'),
            padx=20, pady=5, cursor='hand2'
        ).pack()

