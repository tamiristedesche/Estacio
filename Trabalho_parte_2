    # -----------------------------------------------------------------
    def abrir_busca(self):
        """
        FUNÇÃO: abrir_busca()
        OBJETIVO: Abrir uma janela para buscar alunos por nome ou matrícula
        """
        janela = Toplevel(self.root)
        janela.title("Buscar Aluno")
        janela.geometry("800x500")
        janela.configure(bg='#f0f0f0')
        
        # Frame superior com o campo de busca
        frame_busca = tk.Frame(janela, bg='#f0f0f0', pady=15)
        frame_busca.pack(fill=tk.X, padx=20)
        
        tk.Label(frame_busca, text="Pesquisar:", font=('Arial', 11, 'bold'), 
                bg='#f0f0f0').pack(side=tk.LEFT, padx=10)
        
        entry_busca = tk.Entry(frame_busca, font=('Arial', 11), width=40)
        entry_busca.pack(side=tk.LEFT, padx=10)
        
        # Frame para exibir os resultados
        frame_resultados = tk.Frame(janela, bg='#f0f0f0')
        frame_resultados.pack(fill=tk.BOTH, expand=True, padx=20, pady=10)
        
        # Scrollbar para a tabela de resultados
        scroll_y = ttk.Scrollbar(frame_resultados)
        scroll_y.pack(side=tk.RIGHT, fill=tk.Y)
        
        # Tabela de resultados
        tree_busca = ttk.Treeview(frame_resultados, 
                                  columns=('ID', 'Nome', 'Matrícula', 'Curso', 'Nota 1', 'Nota 2', 'Média', 'Situação'), 
                                  show='headings', 
                                  yscrollcommand=scroll_y.set, 
                                  height=15)
        scroll_y.config(command=tree_busca.yview)
        
        # Configurar colunas da tabela de busca
        colunas_busca = ['ID', 'Nome', 'Matrícula', 'Curso', 'Nota 1', 'Nota 2', 'Média', 'Situação']
        for col in colunas_busca:
            tree_busca.heading(col, text=col)
            tree_busca.column(col, width=100)
        
        tree_busca.pack(fill=tk.BOTH, expand=True)

        # -----------------------------------------------------------------
        # FUNÇÃO INTERNA: Realizar a busca
        # -----------------------------------------------------------------
        def pesquisar():
            """
            FUNÇÃO INTERNA: pesquisar()
            OBJETIVO: Realizar a busca no banco de dados e exibir os resultados
            """
            # Limpar resultados anteriores
            for item in tree_busca.get_children():
                tree_busca.delete(item)
            
            termo = entry_busca.get().strip()
            if not termo:
                messagebox.showwarning("Aviso", "Digite um termo para buscar!")
                return
            
            # Buscar no banco de dados
            resultados = buscar_aluno(termo)
            
            if not resultados:
                messagebox.showinfo("Info", "Nenhum aluno encontrado!")
                return
            
            # Exibir os resultados na tabela
            for aluno in resultados:
                id_aluno, nome, matricula, curso, nota1, nota2 = aluno
                if nota1 is not None and nota2 is not None:
                    media = (nota1 + nota2) / 2
                    situacao = "APROVADO ✅" if media >= 6 else "REPROVADO ❌"
                elif nota1 is not None and nota2 is None:
                    media = nota1 / 2
                    situacao = "APROVADO ✅" if media >= 6 else "REPROVADO ❌"
                elif nota1 is None and nota2 is not None:
                    media = nota2 / 2
                    situacao = "APROVADO ✅" if media >= 6 else "REPROVADO ❌"
                else:
                    media = 0
                    situacao = "SEM NOTAS ⚠️"
                
                tree_busca.insert('', tk.END, values=(
                    id_aluno, nome, matricula, curso, 
                    f"{nota1:.1f}" if nota1 else "-", 
                    f"{nota2:.1f}" if nota2 else "-",
                    f"{media:.1f}", situacao
                ))
        
        # Botão BUSCAR
        tk.Button(frame_busca, text="BUSCAR", command=pesquisar, 
                 bg='#3498db', fg='white', font=('Arial', 10, 'bold'), 
                 padx=20, pady=5, cursor='hand2').pack(side=tk.LEFT, padx=10)
        
        # Permitir buscar pressionando Enter
        entry_busca.bind('<Return>', lambda e: pesquisar())

