# -----------------------------------------------------------------
# CREATE: Cadastrar novo aluno
# -----------------------------------------------------------------
def cadastrar_aluno(nome, matricula, curso, nota1, nota2):
    """
    FUNÇÃO: cadastrar_aluno()
    OBJETIVO: Inserir um novo aluno no banco de dados
    PARÂMETROS: 
        - nome (string): Nome completo do aluno
        - matricula (string): Número de matrícula (deve ser único)
        - curso (string): Nome do curso
        - nota1 (float): Primeira nota (0 a 10)
        - nota2 (float): Segunda nota (0 a 10)
    RETORNA: True (sucesso) ou False (erro, geralmente matrícula duplicada)
    """
    try:
        # 1. Conectar ao banco
        conexao = conectar()
        cursor = conexao.cursor()
        
        # 2. Executar o INSERT SQL
        cursor.execute("""
            INSERT INTO alunos (nome, matricula, curso, nota1, nota2)
            VALUES (?, ?, ?, ?, ?)
        """, (nome, matricula, curso, nota1, nota2))
        
        # 3. Salvar e fechar
        conexao.commit()
        conexao.close()
        return True  # Cadastro realizado com sucesso
        
    except sqlite3.IntegrityError:
        # Este erro ocorre quando a matrícula já existe
        return False  # Falha no cadastro


# -----------------------------------------------------------------
# READ: Listar todos os alunos
# -----------------------------------------------------------------
def listar_alunos():
    """
    FUNÇÃO: listar_alunos()
    OBJETIVO: Buscar todos os alunos cadastrados
    RETORNA: Lista de tuplas [(id, nome, matricula, curso, nota1, nota2)]
    OBSERVAÇÃO: Os alunos são ordenados por ID (ordem de cadastro)
    """
    # 1. Conectar ao banco
    conexao = conectar()
    cursor = conexao.cursor()
    
    # 2. Executar a consulta SQL (ORDER BY id para ordenar)
    cursor.execute("""
        SELECT id, nome, matricula, curso, nota1, nota2
        FROM alunos
        ORDER BY id
    """)
    
    # 3. Buscar todos os resultados
    alunos = cursor.fetchall()
    
    # 4. Fechar a conexão
    conexao.close()
    return alunos


# -----------------------------------------------------------------
# READ: Buscar aluno por nome ou matrícula
# -----------------------------------------------------------------
def buscar_aluno(termo):
    """
    FUNÇÃO: buscar_aluno()
    OBJETIVO: Encontrar alunos pelo nome ou matrícula
    PARÂMETRO: termo - texto digitado pelo usuário
    RETORNA: Lista de alunos que correspondem à busca
    OBSERVAÇÃO: O símbolo % significa "qualquer caractere"
    Exemplo: %joão% encontra "João", "Joãozinho", "Maria João"
    """
    # 1. Conectar ao banco
    conexao = conectar()
    cursor = conexao.cursor()
    
    # 2. Executar a busca com LIKE (busca parcial)
    cursor.execute("""
        SELECT id, nome, matricula, curso, nota1, nota2
        FROM alunos
        WHERE nome LIKE ? OR matricula LIKE ?
        ORDER BY id
    """, (f"%{termo}%", f"%{termo}%"))
    
    # 3. Buscar os resultados
    resultados = cursor.fetchall()
    
    # 4. Fechar a conexão
    conexao.close()
    return resultados


# -----------------------------------------------------------------
# UPDATE: Atualizar dados de um aluno
# -----------------------------------------------------------------
def atualizar_aluno(id_aluno, nome, curso, nota1, nota2):
    """
    FUNÇÃO: atualizar_aluno()
    OBJETIVO: Modificar os dados de um aluno existente
    PARÂMETROS: id_aluno (identificador), nome, curso, nota1, nota2
    """
    # 1. Conectar ao banco
    conexao = conectar()
    cursor = conexao.cursor()
    
    # 2. Executar o UPDATE SQL
    cursor.execute("""
        UPDATE alunos
        SET nome = ?, curso = ?, nota1 = ?, nota2 = ?
        WHERE id = ?
    """, (nome, curso, nota1, nota2, id_aluno))
    
    # 3. Salvar e fechar
    conexao.commit()
    conexao.close()


# -----------------------------------------------------------------
# DELETE: Excluir um aluno
# -----------------------------------------------------------------
def excluir_aluno(id_aluno):
    """
    FUNÇÃO: excluir_aluno()
    OBJETIVO: Remover um aluno do banco de dados
    PARÂMETRO: id_aluno (identificador do aluno a ser removido)
    """
    # 1. Conectar ao banco
    conexao = conectar()
    cursor = conexao.cursor()
    
    # 2. Executar o DELETE SQL
    cursor.execute("DELETE FROM alunos WHERE id = ?", (id_aluno,))
    
    # 3. Salvar e fechar
    conexao.commit()
    conexao.close()


# -----------------------------------------------------------------
# FUNÇÃO AUXILIAR: Buscar aluno por ID
# -----------------------------------------------------------------
def buscar_aluno_por_id(id_aluno):
    """
    FUNÇÃO: buscar_aluno_por_id()
    OBJETIVO: Buscar um aluno específico pelo seu ID
    PARÂMETRO: id_aluno (identificador do aluno)
    RETORNA: Tupla com os dados do aluno ou None se não encontrar
    OBSERVAÇÃO: Esta função é usada principalmente na atualização,
                para carregar os dados atuais do aluno selecionado
    """
    # 1. Conectar ao banco
    conexao = conectar()
    cursor = conexao.cursor()
    
    # 2. Buscar o aluno pelo ID (WHERE id = ?)
    cursor.execute("""
        SELECT id, nome, matricula, curso, nota1, nota2 
        FROM alunos 
        WHERE id = ?
    """, (id_aluno,))
    
    # 3. Retornar apenas um registro (ou None)
    aluno = cursor.fetchone()
    
    # 4. Fechar a conexão
    conexao.close()
    return aluno


# -----------------------------------------------------------------
# FUNÇÃO AUXILIAR: Verificar se matrícula já existe
# -----------------------------------------------------------------
def verificar_matricula_existe(matricula, id_excluir=None):
    """
    FUNÇÃO: verificar_matricula_existe()
    OBJETIVO: Verificar se uma matrícula já está cadastrada no banco
    PARÂMETROS: 
        - matricula (string): a matrícula a ser verificada
        - id_excluir (int, opcional): ID do aluno a ser ignorado na verificação
                                      (usado na atualização para não conflitar com o próprio aluno)
    RETORNA: True se a matrícula já existe, False se está disponível
    
    EXEMPLO DE USO:
        No cadastro: verificar_matricula_existe("123456") -> True/False
        Na atualização: verificar_matricula_existe("123456", id_aluno=5) 
                       -> ignora o aluno de ID 5 na verificação
    """
    # 1. Conectar ao banco
    conexao = conectar()
    cursor = conexao.cursor()
    
    # 2. Verificar se a matrícula existe (com ou sem exclusão)
    if id_excluir:
        # Na atualização: verifica se a matrícula existe em outro aluno (ignora o próprio)
        cursor.execute("""
            SELECT id FROM alunos 
            WHERE matricula = ? AND id != ?
        """, (matricula, id_excluir))
    else:
        # No cadastro: verifica se a matrícula existe em qualquer aluno
        cursor.execute("""
            SELECT id FROM alunos 
            WHERE matricula = ?
        """, (matricula,))
    
    # 3. Se encontrou algum registro, retorna True
    existe = cursor.fetchone()
    
    # 4. Fechar a conexão
    conexao.close()
    return existe is not None


