        entry_nota2 = tk.Entry(frame_form, font=('Arial', 10), width=35)
        entry_nota2.insert(0, str(nota2))
        entry_nota2.grid(row=4, column=1, pady=8, padx=10)
        
        # -----------------------------------------------------------------
        # FUNÇÃO INTERNA: Salvar as alterações
        # -----------------------------------------------------------------
        def salvar():
            """
            FUNÇÃO INTERNA: salvar()
            OBJETIVO: Validar e salvar as alterações do aluno
            """
            novo_nome = entry_nome.get().strip()
            novo_curso = entry_curso.get().strip()
            
            if not novo_nome or not novo_curso:
                messagebox.showerror("Erro", "Nome e Curso são obrigatórios!")
                return
            
            try:
                nova_nota1 = float(entry_nota1.get())
                nova_nota2 = float(entry_nota2.get())
                if not (0 <= nova_nota1 <= 10 and 0 <= nova_nota2 <= 10):
                    messagebox.showerror("Erro", "Notas devem estar entre 0 e 10!")
                    return
            except ValueError:
                messagebox.showerror("Erro", "Notas devem ser números!")
                return
            
            # Atualizar no banco de dados
            atualizar_aluno(id_aluno, novo_nome, novo_curso, nova_nota1, nova_nota2)
            messagebox.showinfo("Sucesso", "✅ Dados atualizados com sucesso!")
            janela.destroy()
            self.atualizar_tabela()  # Atualizar a tabela principal
        
        # Botões SALVAR e CANCELAR
        frame_botoes = tk.Frame(frame_form, bg='#f0f0f0')
        frame_botoes.grid(row=5, column=0, columnspan=2, pady=25)
        
        tk.Button(frame_botoes, text="SALVAR", command=salvar, 
                 bg='#f39c12', fg='white', font=('Arial', 10, 'bold'), 
                 padx=25, pady=8, cursor='hand2').pack(side=tk.LEFT, padx=10)
        
        tk.Button(frame_botoes, text="CANCELAR", command=janela.destroy, 
                 bg='#95a5a6', fg='white', font=('Arial', 10, 'bold'), 
                 padx=25, pady=8, cursor='hand2').pack(side=tk.LEFT, padx=10)


