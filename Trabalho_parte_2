# -----------------------------------------------------------------
# FUNÇÃO: Conectar ao banco de dados
# -----------------------------------------------------------------
def conectar():
    """
    FUNÇÃO: conectar()
    OBJETIVO: Abrir a conexão com o banco de dados
    RETORNA: Um objeto de conexão com o arquivo escola.db
    """
    return sqlite3.connect("sistema_academico.db")


# -----------------------------------------------------------------
# FUNÇÃO: Criar tabela de alunos
# -----------------------------------------------------------------
def criar_tabela():
    """
    FUNÇÃO: criar_tabela()
    OBJETIVO: Criar a tabela 'alunos' se ela não existir
    OBSERVAÇÃO: Esta função é chamada apenas uma vez, no início do programa

    ESTRUTURA DA TABELA:
        - id: Identificador único (automático)
        - nome: Nome completo do aluno (obrigatório)
        - matricula: Número de matrícula (único e obrigatório)
        - curso: Nome do curso (obrigatório)
        - nota1: Primeira nota do aluno (0 a 10)
        - nota2: Segunda nota do aluno (0 a 10)
    """
    # 1. Conectar ao banco
    conexao = conectar()
    cursor = conexao.cursor()
    
    # 2. Comando SQL para criar a tabela
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS alunos (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nome TEXT NOT NULL,
            matricula TEXT UNIQUE NOT NULL,
            curso TEXT NOT NULL,
            nota1 REAL,
            nota2 REAL
        )
    """)
    
    # 3. Salvar as alterações e fechar a conexão
    conexao.commit()
    conexao.close()


